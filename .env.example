# ============================================================================
# QUICK START: Only GROQ_API_KEY is required
# Get from https://console.groq.com/keys
# ============================================================================

# REQUIRED - Primary LLM provider
GROQ_API_KEY=gsk_your_key_here

# OPTIONAL - Backup Groq keys (leave blank to skip)
GROQ_API_KEY_B=
GROQ_API_KEY_C=

# OPTIONAL - AWS Bedrock fallback (leave blank to skip)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0

# OPTIONAL - HuggingFace fallback (leave blank to skip)
HF_API_KEY=

# Local GGUF (automatic, no config needed - model in repo)
LOCAL_MODEL_NAME=local-gguf
LLAMA_N_GPU_LAYERS=35

# OPTIONAL - Ollama local server (leave blank to skip)
OLLAMA_BASE_URL=http://localhost:11434

# OPTIONAL - Cloud features (leave blank to skip)
LANGSMITH_API_KEY=
AWS_S3_BUCKET=

# API
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# OCR (Windows only - leave blank on Linux/macOS)
# Adjust to your Tesseract installation path if needed
TESSERACT_CMD=